---
// Lógica en Node/TS si la necesitas (Por ahora vacío)
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mi Negocio de Software">
  <main class="bg-slate-900 text-white min-h-screen font-sans">
    
    <section class="max-w-5xl mx-auto px-6 py-24 text-center">
      <h1 class="text-5xl font-extrabold tracking-tight bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
        Soluciones de Software a la Medida
      </h1>
      <p class="mt-6 text-lg text-slate-400 max-w-2xl mx-auto">
        Transformamos tus ideas en aplicaciones web estables, rápidas y optimizadas.
      </p>
      <div class="mt-10">
        <a href="#contacto" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-lg transition">
          Cotizar Proyecto
        </a>
      </div>
    </section>

  </main>
</Layout>